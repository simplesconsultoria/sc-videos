<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:plone="http://namespaces.plone.org/plone"
    i18n_domain="sc.videos"
    >

  <plone:service
      method="POST"
      factory=".post.VideoMetadataPostService"
      for="plone.dexterity.interfaces.IDexterityContent"
      permission="sc.videos.video.add"
      layer="sc.videos.interfaces.IBrowserLayer"
      name="@video-metadata"
      />

</configure>
