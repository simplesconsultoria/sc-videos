<configure xmlns="http://namespaces.zope.org/zope">

  <utility
      factory="sc.videos.integration.youtube.data.YouTubeMetadataProvider"
      provides="sc.videos.interfaces.IVideoMetadataProvider"
      name="youtube"
      />

  <utility
      factory="sc.videos.integration.vimeo.data.VimeoMetadataProvider"
      provides="sc.videos.interfaces.IVideoMetadataProvider"
      name="vimeo"
      />

</configure>
