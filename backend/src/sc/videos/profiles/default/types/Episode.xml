<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Dexterity FTI"
        name="Episode"
        i18n:domain="sc.videos"
>

  <!-- Basic properties -->
  <property name="title"
            i18n:translate=""
  >Episode</property>
  <property name="description"
            i18n:translate=""
  >A video episode within a series</property>

  <property name="allow_discussion">True</property>
  <property name="factory">Episode</property>

  <!-- Hierarchy control -->
  <property name="filter_content_types">True</property>
  <property name="allowed_content_types">
    <element value="Image" />
  </property>
  <property name="global_allow">True</property>

  <!-- Schema, class and security -->
  <property name="add_permission">sc.videos.episode.add</property>
  <property name="klass">sc.videos.content.episode.Episode</property>
  <property name="schema">sc.videos.content.episode.IEpisode</property>

  <!-- Enabled behaviors -->
  <property name="behaviors"
            purge="true"
  >
    <element value="plone.basic" />
    <element value="sc.videos.remotevideo" />
    <element value="plone.namefromtitle" />
    <element value="volto.blocks" />
    <element value="volto.preview_image" />
    <element value="plone.categorization" />
    <element value="plone.shortname" />
    <element value="plone.versioning" />
  </property>

  <!-- View information -->
  <property name="add_view_expr">string:${folder_url}/++add++Episode</property>
  <property name="immediate_view">view</property>
  <property name="default_view">view</property>
  <property name="default_view_fallback">False</property>
  <property name="view_methods">
    <element value="view" />
  </property>
</object>
