<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Dexterity FTI"
        name="Series"
        i18n:domain="sc.videos"
>

  <!-- Basic properties -->
  <property name="title"
            i18n:translate=""
  >Series</property>
  <property name="description"
            i18n:translate=""
  >A series of video episodes</property>

  <property name="allow_discussion">True</property>
  <property name="factory">Series</property>

  <!-- Hierarchy control -->
  <property name="filter_content_types">False</property>
  <property name="allowed_content_types" />
  <property name="global_allow">True</property>

  <!-- Schema, class and security -->
  <property name="add_permission">sc.videos.series.add</property>
  <property name="klass">sc.videos.content.series.Series</property>
  <property name="schema">sc.videos.content.series.ISeries</property>

  <!-- Enabled behaviors -->
  <property name="behaviors"
            purge="true"
  >
    <element value="plone.basic" />
    <element value="plone.namefromtitle" />
    <element value="volto.blocks" />
    <element value="volto.preview_image" />
    <element value="plone.categorization" />
    <element value="plone.shortname" />
    <element value="plone.excludefromnavigation" />
  </property>

  <!-- View information -->
  <property name="add_view_expr">string:${folder_url}/++add++Series</property>
  <property name="immediate_view">view</property>
  <property name="default_view">view</property>
  <property name="default_view_fallback">False</property>
  <property name="view_methods">
    <element value="view" />
  </property>
</object>
