<configure xmlns="http://namespaces.zope.org/zope">

  <!-- Indexers/Metadata -->
  <adapter
      factory=".video.video_url"
      name="videoUrl"
      />

  <adapter
      factory=".video.duration"
      name="duration"
      />

  <adapter
      factory=".video.has_video"
      name="has_video"
      />

</configure>
